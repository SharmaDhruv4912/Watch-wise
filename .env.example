# Database (Neon, Supabase, or local PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/watchwise?schema=public"

# Clerk authentication — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Razorpay payments — https://dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Email (Resend) — https://resend.com
RESEND_API_KEY=
EMAIL_FROM="Watchwise India <hello@watchwise.in>"
ADMIN_EMAIL="you@example.com"

# Affiliate networks (optional — tag appended to Amazon India links)
AMAZON_AFFILIATE_TAG=

# Consultation scheduling
NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/your-handle/watch-consultation"

# Site URL (used for metadata and redirects)
NEXT_PUBLIC_SITE_URL="https://watchwise.in"
